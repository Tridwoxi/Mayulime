#!/bin/sh
set -eu

# Messages must use Conventional Commits: https://www.conventionalcommits.org/en/v1.0.0/
# Scope is required, but may be whatever feels fitting.

message_file="$1"
first_line="$(head -n 1 "$message_file" | tr -d '\r')"

# Allow Git-generated commits that don't follow Conventional Commits.
case "$first_line" in
  "Merge "*|"Revert "*)
    exit 0
    ;;
esac

conventional_regex='^(build|chore|ci|docs|feat|fix|perf|refactor|style|test)\([a-z0-9-]+\)(!)?: [[:print:]]+$'

if printf '%s' "$first_line" | grep -Eq "$conventional_regex"; then
  exit 0
fi

cat <<'EOF'
Use conventional commits message format:
    type(scope): subject
Types:
    build|chore|ci|docs|feat|fix|perf|refactor|style|test
EOF

exit 1
