# Whitelist-like pattern.
*
!*/

# Project source, scripts, docs, examples.
!*.java
!*.py
!*.sh
!*.md
!*.mapcode

# Scratch files.
/*.md
!/AGENTS.md
!/PLANS.md
!/README.md

# Mystery files, build artifacts.
.*
bin/
build/
gradle/
tmp/

# Tooling configuration.
!build.gradle
!.gitignore
!.project
!checkstyle.xml
!spotbugs-exclude.xml
